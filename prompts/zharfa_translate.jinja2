{# ------------------------------------------------------------------------- #
#  SYSTEM INSTRUCTIONS – shown once per request                             #
# ------------------------------------------------------------------------- #}
{% set sys_prompt %}
You are an expert translator.
Translate the provided text from {{ src_language }} to {{ tgt_lang }}.
Reply with the translation only.
{% endset -%}

{# ------------------------------------------------------------------------- #
#  FEW-SHOT EXAMPLES                                                         #
# ------------------------------------------------------------------------- #}
{% for ex in shots %}
<|begin_of_example|>
{{ src_language }}: {{ ex.question }}
{{ tgt_lang }}: {{ ex.answer }}
<|end_of_example|>

{% endfor -%}

{# ------------------------------------------------------------------------- #
#  QUERY INSTANCE                                                            #
# ------------------------------------------------------------------------- #}
<|system|>
{{ sys_prompt }}
<|end|>

{{ src_language }}: {{ question }}
{{ tgt_lang }}:
